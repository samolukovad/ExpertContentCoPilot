<odoo>
  <record id="view_publication_stat_tree" model="ir.ui.view">
    <field name="name">content.publication.stat.tree</field>
    <field name="model">content.publication.stat</field>
    <field name="arch" type="xml">
      <list string="Аналитика публикаций">
        <field name="title"/>
        <field name="platform"/>
        <field name="date"/>
        <field name="views"/>
        <field name="likes"/>
        <field name="comments"/>
        <field name="reposts"/>
      </list>
    </field>
  </record>

  <record id="view_publication_stat_form" model="ir.ui.view">
    <field name="name">content.publication.stat.form</field>
    <field name="model">content.publication.stat</field>
    <field name="arch" type="xml">
      <form string="Статистика публикации">
        <sheet>
          <group>
            <field name="title"/>
            <field name="platform"/>
            <field name="date"/>
            <field name="views"/>
            <field name="likes"/>
            <field name="comments"/>
            <field name="reposts"/>
            <field name="user_id"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_publication_stat_graph" model="ir.ui.view">
    <field name="name">content.publication.stat.graph</field>
    <field name="model">content.publication.stat</field>
    <field name="arch" type="xml">
      <graph string="Динамика" type="line">
        <field name="date" type="row"/>
        <field name="views" type="measure"/>
        <field name="likes" type="measure"/>
      </graph>
    </field>
  </record>

  <record id="action_publication_stat" model="ir.actions.act_window">
    <field name="name">Аналитика публикаций</field>
    <field name="res_model">content.publication.stat</field>
    <field name="view_mode">list,form,graph</field>
  </record>

  <menuitem id="menu_publication_stat_root" name="Аналитика" sequence="50"/>
  <menuitem id="menu_publication_stat" name="Публикации" parent="menu_publication_stat_root" action="action_publication_stat"/>
</odoo>
