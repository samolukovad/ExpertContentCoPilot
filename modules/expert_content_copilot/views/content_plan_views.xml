<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_content_plan_list" model="ir.ui.view">
        <field name="name">content.plan.list</field>
        <field name="model">content.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="status"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="manager_id"/>
                <field name="article_count"/>
            </list>
        </field>
    </record>

    <record id="view_content_plan_form" model="ir.ui.view">
        <field name="name">content.plan.form</field>
        <field name="model">content.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="status"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="manager_id"/>
                    </group>

                    <group>
                        <field name="description"/>
                        <field name="goal"/>
                    </group>

                    <group string="Targets">
                        <field name="target_articles"/>
                        <field name="target_views"/>
                    </group>

                    <group string="Statistics">
                        <field name="article_count" readonly="1"/>
                        <field name="published_count" readonly="1"/>
                        <field name="scheduled_count" readonly="1"/>
                        <field name="draft_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Team">
                            <field name="team_member_ids"/>
                        </page>
                        <page string="Articles">
                            <field name="article_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_content_plan_kanban" model="ir.ui.view">
        <field name="name">content.plan.kanban</field>
        <field name="model">content.plan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="status"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="manager_id"/>
                <field name="article_count"/>
                <templates>
                    <t t-name="card">
                        <field class="fw-bold fs-5" name="name"/>
                        <div>
                            <field name="status"/>
                        </div>
                        <div>
                            <span>Start: </span>
                            <field name="start_date"/>
                        </div>
                        <div>
                            <span>End: </span>
                            <field name="end_date"/>
                        </div>
                        <div>
                            <span>Manager: </span>
                            <field name="manager_id"/>
                        </div>
                        <footer>
                            <span>Articles: </span>
                            <field name="article_count"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_content_plan_calendar" model="ir.ui.view">
        <field name="name">content.plan.calendar</field>
        <field name="model">content.plan</field>
        <field name="arch" type="xml">
            <calendar string="Content Plans"
                      date_start="start_date"
                      date_stop="end_date"
                      color="manager_id"
                      mode="month">
                <field name="name"/>
                <field name="status"/>
                <field name="manager_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_content_plan" model="ir.actions.act_window">
        <field name="name">Content Plans</field>
        <field name="res_model">content.plan</field>
        <field name="view_mode">kanban,calendar,list,form</field>
    </record>

    <menuitem id="menu_content_plans"
              name="Content Plans"
              parent="menu_content_root"
              action="action_content_plan"
              sequence="30"/>

</odoo>
