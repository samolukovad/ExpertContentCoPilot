<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_content_article_list" model="ir.ui.view">
        <field name="name">content.article.list</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="status"/>
                <field name="category"/>
                <field name="scheduled_date"/>
                <field name="publish_date"/>
                <field name="author_id"/>
                <field name="reviewer_id"/>
            </list>
        </field>
    </record>

    <record id="view_content_article_form" model="ir.ui.view">
        <field name="name">content.article.form</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="status"/>
                        <field name="category"/>
                        <field name="date"/>
                    </group>

                    <group>
                        <field name="scheduled_date"/>
                        <field name="publish_date"/>
                        <field name="author_id"/>
                        <field name="reviewer_id"/>
                    </group>

                    <group>
                        <field name="idea_id"/>
                        <field name="plan_id"/>
                        <field name="tags"/>
                        <field name="keywords"/>
                    </group>

                    <notebook>
                        <page string="Content">
                            <field name="text"/>
                        </page>
                        <page string="AI Suggestions">
                            <field name="ai_suggestions"/>
                            <field name="structure_score"/>
                        </page>
                        <page string="Analytics">
                            <group>
                                <field name="views"/>
                                <field name="likes"/>
                                <field name="shares"/>
                                <field name="comments"/>
                                <field name="word_count" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_content_article_kanban" model="ir.ui.view">
        <field name="name">content.article.kanban</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="title"/>
                <field name="status"/>
                <field name="category"/>
                <field name="scheduled_date"/>
                <field name="publish_date"/>
                <field name="author_id"/>
                <templates>
                    <t t-name="card">
                        <field class="fw-bold fs-5" name="title"/>
                        <div>
                            <field name="category"/>
                        </div>
                        <div>
                            <span>Status: </span>
                            <field name="status"/>
                        </div>
                        <div>
                            <span>Scheduled: </span>
                            <field name="scheduled_date"/>
                        </div>
                        <div>
                            <span>Publish: </span>
                            <field name="publish_date"/>
                        </div>
                        <footer>
                            <span>Author: </span>
                            <field name="author_id"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_content_article_calendar" model="ir.ui.view">
        <field name="name">content.article.calendar</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <calendar string="Article Schedule"
                      date_start="scheduled_date"
                      color="author_id"
                      mode="month">
                <field name="title"/>
                <field name="status"/>
                <field name="category"/>
                <field name="author_id"/>
                <field name="publish_date"/>
            </calendar>
        </field>
    </record>

    <record id="action_content_article" model="ir.actions.act_window">
        <field name="name">Articles</field>
        <field name="res_model">content.article</field>
        <field name="view_mode">kanban,calendar,list,form</field>
    </record>

    <menuitem id="menu_content_articles"
              name="Articles"
              parent="menu_content_root"
              action="action_content_article"
              sequence="20"/>

</odoo>
