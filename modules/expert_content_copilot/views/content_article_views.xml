<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_content_article_list" model="ir.ui.view">
        <field name="name">content.article.list</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="status"/>
                <field name="date"/>
                <field name="author_id"/>
            </list>
        </field>
    </record>

    <record id="view_content_article_form" model="ir.ui.view">
        <field name="name">content.article.form</field>
        <field name="model">content.article</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="status"/>
                        <field name="date"/>
                        <field name="author_id"/>
                        <field name="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_content_article" model="ir.actions.act_window">
        <field name="name">Articles</field>
        <field name="res_model">content.article</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_content_articles" name="Articles" parent="menu_content_root" action="action_content_article" sequence="20"/>
</odoo>