<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_content_idea_list" model="ir.ui.view">
        <field name="name">content.idea.list</field>
        <field name="model">content.idea</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="status"/>
                <field name="date"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_content_idea_form" model="ir.ui.view">
        <field name="name">content.idea.form</field>
        <field name="model">content.idea</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="status"/>
                        <field name="date"/>
                        <field name="user_id"/>
                        <field name="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_content_idea" model="ir.actions.act_window">
        <field name="name">Content Ideas</field>
        <field name="res_model">content.idea</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first content idea!
            </p>
        </field>
    </record>

    <menuitem id="menu_content_root" name="Expert Content" sequence="10"/>
    <menuitem id="menu_content_ideas" name="Ideas" parent="menu_content_root" action="action_content_idea" sequence="10"/>
</odoo>